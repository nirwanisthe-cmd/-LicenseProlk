rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields:
    //   - name: string (required)
    //   - slug: string (required, unique)
    //   - price: number (required)
    //   - status: string (required, enum: ['active', 'inactive'])
    //   - ... other optional fields
    //
    // Collection: orders
    // Fields:
    //   - order_number: string (required)
    //   - customer_name: string (required)
    //   - customer_email: string (required)
    //   - total_amount: number (required)
    //   - uid: string (optional, for ownership)
    //   - ... other fields
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "nirwanisthe@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Products: Publicly readable if active, admin can do anything
    match /products/{productId} {
      allow read: if resource.data.status == 'active' || isAdmin();
      allow write: if isAdmin();
    }

    // Orders: Owner can read/write their own orders, admin can read all
    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Users: Private profile data
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Settings: Admin only
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }
  }
}
